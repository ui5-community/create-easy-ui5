# Enforce `engines.node` from package.json at install time — installs on
# unsupported Node versions fail loudly instead of silently working until
# a deep dep crashes.
engine-strict=true

# Always write a lockfile and prefer exact resolutions in saved deps so
# that semver drift on `npm install` can't silently pull a freshly
# republished (potentially trojanized) version.
package-lock=true
save-exact=true
