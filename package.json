{
  "name": "create-easy-ui5",
  "version": "1.1.0",
  "description": "npm-init wrapper for Easy-UI5",
  "bin": {
    "easy-ui5": "index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ui5-community/create-easy-ui5.git"
  },
  "keywords": [],
  "author": "Peter Muessig",
  "license": "Apache 2.0",
  "bugs": {
    "url": "https://github.com/ui5-community/create-easy-ui5/issues"
  },
  "homepage": "https://github.com/ui5-community/create-easy-ui5#readme",
  "engines": {
    "node": ">=20.17.0"
  },
  "files": [
    "index.js"
  ],
  "scripts": {
    "start": "node index.js",
    "format": "prettier --write .",
    "prepare": "node ./.husky/skip.js || husky",
    "hooks:pre-commit": "lint-staged",
    "hooks:commit-msg": "commitlint -e",
    "changeset": "changeset",
    "changeset:empty": "changeset --empty",
    "version-package": "changeset version && npm install --package-lock-only",
    "release-publish": "changeset publish"
  },
  "dependencies": {
    "generator-easy-ui5": "^3.9.1",
    "yeoman-environment": "^5.1.2"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "20.2.0",
    "@commitlint/config-conventional": "20.2.0",
    "cz-conventional-changelog": "3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "^3.8.4"
  },
  "lint-staged": {
    "*.{ts,js,json,md,yml}": [
      "prettier --write ."
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
